<% model = SdrViewComponents::Forms::SelectFieldComponentPreview::SelectFieldPreviewModel.new(resource_type: 'image') %>

<%= form_with(model: model, url: '/example') do |form| %>
  <%= render SdrViewComponents::Forms::SelectFieldComponent.new(
        form: form,
        field_name: :resource_type,
        options: [
          %w[Book book],
          %w[Image image],
          %w[Map map]
        ]
      ) %>
<% end %>
